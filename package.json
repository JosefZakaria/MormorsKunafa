{
  "name": "mormors-kunafa-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "mobile": "npm run start --workspace=apps/mobile",
    "mobile:android": "npm run android --workspace=apps/mobile",
    "mobile:ios": "npm run ios --workspace=apps/mobile",
    "web": "npm run dev --workspace=apps/web",
    "web:build": "npm run build --workspace=apps/web",
    "web:preview": "npm run preview --workspace=apps/web"
  },
  "devDependencies": {
    "typescript": "~5.6.2"
  }
}

