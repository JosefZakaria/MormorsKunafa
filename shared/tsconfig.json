{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true
  },
  "include": [
    "api/**/*.ts",
    "constants/**/*.ts",
    "types/**/*.ts",
    "utils/**/*.ts",
    "validation/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "utils/**/*.d.ts"]
}
