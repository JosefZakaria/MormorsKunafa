{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true
  },
  "include": [
    "api/**/*.ts",
    "types/**/*.ts",
    "validation/**/*.ts",
    "utils/**/*.ts",
    "constants/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
