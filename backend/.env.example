# Required for API (Supabase)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Required for admin login
JWT_SECRET=

# Server (local dev only; Vercel sets NODE_ENV=production)
PORT=3001

# CORS — production frontend origin(s)
FRONTEND_URL=https://mormorskunafa.se
PUBLIC_WEB_APP_URL=https://mormorskunafa.se

# Stripe (card payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Order emails (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
SITE_PUBLIC_URL=https://mormorskunafa.se

# Optional: SMS (Sinch)
SINCH_PROJECT_ID=
SINCH_KEY_ID=
SINCH_KEY_SECRET=
SINCH_APP_ID=

# Optional: admin stats / delete history
STATS_PASSWORD=
DELETE_PASSWORD=

# Optional: server-side receipt printer (local network only)
PRINTER_IP=192.168.1.100

# Optional: Swish (requires bank certificates on server filesystem)
SWISH_ENV=test
SWISH_PAYEE_ALIAS=
SWISH_CERT_PATH=
SWISH_KEY_PATH=
SWISH_CALLBACK_BASE_URL=
