{
  "version": 2,
  "installCommand": "cd .. && npm ci",
  "buildCommand": "npm run build",
  "builds": [
    {
      "src": "dist/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/index.js"
    }
  ],
  "functions": {
    "dist/index.js": {
      "includeFiles": "../shared/dist/**"
    }
  }
}
