{
  "version": 2,
  "installCommand": "cd .. && npm ci",
  "buildCommand": "npm run build --workspace=@mormors-kunafa/shared && npm run build",
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "../shared/dist/**"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/index.ts"
    }
  ]
}
